{
  "name": "zod-redact",
  "version": "0.0.1",
  "description": "Data masking plugin for Zod schemas — redact, anonymize, or replace sensitive fields after validation.",
  "author": "holoflash",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "zod": "^3.24.0 || >=4.0.0"
  },
  "devDependencies": {
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.9",
    "zod": "4.4.3"
  },
  "keywords": [
    "zod",
    "mask",
    "masking",
    "redact",
    "anonymize",
    "pii",
    "schema",
    "plugin",
    "data-masking",
    "privacy"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/holoflash/zod-redact"
  },
  "homepage": "https://github.com/holoflash/zod-redact#readme",
  "bugs": {
    "url": "https://github.com/holoflash/zod-redact/issues"
  }
}
